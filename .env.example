# Copy this file to `.env` and fill in your real values. `.env` is gitignored.

# ── Supabase: client (safe to ship — anon key is RLS-protected) ──────────────
# EXPO_PUBLIC_ prefix REQUIRED. URL is the BASE project URL (no trailing /rest/v1/).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Google Books API key: client — optional but recommended ─────────────────
# Raises the catalog-search quota (keyless access is shared + 429s at scale).
# Free: Google Cloud Console → enable "Books API" → create an API key.
EXPO_PUBLIC_GOOGLE_BOOKS_KEY=your-google-books-api-key

# ── PostHog analytics: client (B6) — safe to ship; leave blank to disable ────
# Without a key the analytics seam is a silent no-op. Host: https://us.i.posthog.com
# (US) or https://eu.i.posthog.com (EU).
EXPO_PUBLIC_POSTHOG_KEY=phc_your_project_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Supabase: server / CLI only — never EXPO_PUBLIC, never in the app bundle ──
SUPABASE_DB_PASSWORD=your-database-password

# Added in later B-phases (edge-function secrets, NOT here):
#   ANTHROPIC_API_KEY        (B6 — set via `supabase secrets set`, never in client)
#   SUPABASE_SERVICE_ROLE_KEY (edge functions only)
