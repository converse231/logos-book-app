{
  "expo": {
    "name": "Logos",
    "slug": "logos",
    "version": "0.0.2",
    "scheme": "logos",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.logos.app"
    },
    "android": {
      "package": "com.logos.app",
      "adaptiveIcon": {
        "backgroundColor": "#F4F1E8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Logos saves your reading share cards to your photo library so you can post them.",
          "photosPermission": "Logos saves your reading share cards to your photo library so you can post them.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Logos uses the camera to scan a book's barcode so you can add it to your shelf instantly."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Logos uses your photos so you can set a profile picture."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9497cadc-7318-4b40-a37a-1eedf34b94ab"
      }
    }
  }
}
