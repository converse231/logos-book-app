{
  "expo": {
    "name": "Quire",
    "slug": "quire",
    "version": "0.0.2",
    "scheme": "quire",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.quire.app"
    },
    "android": {
      "package": "com.quire.app",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "backgroundColor": "#F6EEDF",
        "foregroundImage": "./assets/android-icon.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "Quire saves your reading share cards to your photo library so you can post them.",
          "photosPermission": "Quire saves your reading share cards to your photo library so you can post them.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Quire uses the camera to scan a book's barcode so you can add it to your shelf instantly."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Quire uses your photos so you can set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-screen.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#F7EBD3"
        }
      ],
      "expo-notifications",
      "./plugins/withReadingActivity"
    ],
    "experiments": {},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "61f01791-f40e-4f23-970f-d2498815fd15"
      }
    },
    "owner": "enyeng23"
  }
}
